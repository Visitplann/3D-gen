{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run 5-View Pipeline",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/python/pipeline.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "python": "${workspaceFolder}/.venv/bin/python",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/python",
        "MPLBACKEND": "Agg"
      }
    }
  ]
}
